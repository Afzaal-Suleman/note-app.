<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="main-content">
    <div class="container">
        <!-- Toast Message -->
        <% if (message) { %>
            <div class="toast <%= messageType === 'success' ? 'toast-success' : 'toast-error' %>">
                <%= message %>
            </div>
        <% } %>

        <!-- Quick Actions -->
        <div class="quick-actions">
            <% if (req.session && req.session.isAuthenticated) { %>
                <a href="/notes/create" class="btn-primary btn-large">➕ Create New Note</a>
            <% } %>

        </div>

        <!-- About Section -->
        <div class="about-section">
            <div class="about-content">
                <h2 class="about-title">About KnowledgeFlowApp</h2>
                <div class="about-grid">
                    <div class="about-card">
                        <div class="about-icon">🌊</div>
                        <h3>Seamless Flow</h3>
                        <p>Experience a smooth flow of knowledge. Navigate through content effortlessly with our intuitive interface designed for continuous learning.</p>
                    </div>
                    <div class="about-card">
                        <div class="about-icon">📂</div>
                        <h3>Organized Categories</h3>
                        <p>Browse knowledge by categories to quickly find the information you need. Flow through topics effortlessly.</p>
                    </div>
                    <div class="about-card">
                        <div class="about-icon">🔍</div>
                        <h3>Powerful Search</h3>
                        <p>Search across all knowledge by title, content, category, or tags. Find any information in seconds and keep the flow going.</p>
                    </div>
                    <div class="about-card">
                        <div class="about-icon">⭐</div>
                        <h3>Quick Access</h3>
                        <p>Favorite important knowledge for quick access. Your most important information flows directly to your fingertips.</p>
                    </div>
                    <div class="about-card">
                        <div class="about-icon">🏷️</div>
                        <h3>Smart Tags</h3>
                        <p>Knowledge can have tags like #important, #work, #personal. Click on any tag to see all related content with that label.</p>
                    </div>
                    <div class="about-card">
                        <div class="about-icon">🔒</div>
                        <h3>Secure Access</h3>
                        <p>Your knowledge is securely stored with authentication. Access your personal reading material safely and keep the flow secure.</p>
                    </div>
                </div>
                <div class="about-footer">
                    <p>Built with ❤️ using Node.js, Express, MongoDB, and EJS</p>
                    <p>Version 1.0.0</p>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
