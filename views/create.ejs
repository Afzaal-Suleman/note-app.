<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="main-content">
    <div class="container">
        <div class="form-container">
            <h1 class="page-title">Create New Note</h1>
            
            <% if (errors && errors.length > 0) { %>
                <div class="error-messages">
                    <% errors.forEach(error => { %>
                        <div class="error-message">❌ <%= error %></div>
                    <% }); %>
                </div>
            <% } %>

            <form action="/notes" method="POST" class="note-form">
                <div class="form-group">
                    <label for="title">Title *</label>
                    <input 
                        type="text" 
                        id="title" 
                        name="title" 
                        value="<%= formData.title || '' %>"
                        maxlength="150"
                        required
                        class="form-input"
                        placeholder="Enter note title..."
                    >
                    <small class="form-hint">Maximum 150 characters</small>
                </div>

                <div class="form-group">
                    <label for="content">Content *</label>
                    <textarea 
                        id="content" 
                        name="content" 
                        rows="8"
                        required
                        class="form-textarea"
                        placeholder="Write your note content here..."
                    ><%= formData.content || '' %></textarea>
                </div>

                <div class="form-group">
                    <label for="category">Category</label>
                    <select id="category" name="category" class="form-select">
                        <option value="">Select a category</option>
                        <% categories.forEach(cat => { %>
                            <option value="<%= cat %>" <%= formData.category === cat ? 'selected' : '' %>>
                                <%= cat %>
                            </option>
                        <% }); %>
                    </select>
                </div>

                <div class="form-group">
                    <label for="tags">Tags</label>
                    <input 
                        type="text" 
                        id="tags" 
                        name="tags" 
                        value="<%= formData.tags || '' %>"
                        class="form-input"
                        placeholder="Enter tags separated by commas (e.g., node, javascript, tutorial)"
                    >
                    <small class="form-hint">Separate multiple tags with commas</small>
                </div>

                <div class="form-group checkboxes">
                    <label class="checkbox-label">
                        <input type="checkbox" name="favorite" <%= formData.favorite === 'on' ? 'checked' : '' %>>
                        <span>⭐ Mark as Favorite</span>
                    </label>
                    
                    <label class="checkbox-label">
                        <input type="checkbox" name="pinned" <%= formData.pinned === 'on' ? 'checked' : '' %>>
                        <span>📌 Pin Note</span>
                    </label>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-primary btn-large">Create Note</button>
                    <a href="/" class="btn-secondary btn-large">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
