<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="main-content">
    <div class="container">
        <div class="form-container">
            <h1 class="page-title">Edit Note</h1>
            
            <div class="note-meta-badges" style="margin-bottom: 1.5rem;">
                <span class="badge badge-category"><%= note.category %></span>
                <% if (note.pinned) { %>
                    <span class="badge badge-pinned">📌 Pinned</span>
                <% } %>
                <% if (note.favorite) { %>
                    <span class="badge badge-favorite">⭐ Favorite</span>
                <% } %>
            </div>
            
            <% if (errors && errors.length > 0) { %>
                <div class="error-messages">
                    <% errors.forEach(error => { %>
                        <div class="error-message">❌ <%= error %></div>
                    <% }); %>
                </div>
            <% } %>

            <form action="/notes/<%= note._id %>/update" method="POST" class="note-form">
                <div class="form-group">
                    <label for="title">Title *</label>
                    <input 
                        type="text" 
                        id="title" 
                        name="title" 
                        value="<%= note.title %>"
                        maxlength="150"
                        required
                        class="form-input"
                        placeholder="Enter note title..."
                    >
                    <small class="form-hint">Maximum 150 characters</small>
                </div>

                <div class="form-group">
                    <label for="content">Content *</label>
                    <div class="content-editor"></div>
                    <textarea 
                        id="content" 
                        name="content" 
                        rows="8"
                        class="form-textarea"
                        style="display: none;"
                    ><%= note.content %></textarea>
                </div>

                <div class="form-group">
                    <label for="category">Category</label>
                    <div class="category-input-wrapper">
                        <select id="category" name="category" class="form-select">
                            <option value="">Select a category</option>
                            <% categories.forEach(cat => { %>
                                <option value="<%= cat %>" <%= note.category === cat ? 'selected' : '' %>>
                                    <%= cat %>
                                </option>
                            <% }); %>
                        </select>
                        <span class="category-divider">or</span>
                        <input 
                            type="text" 
                            id="newCategory" 
                            name="newCategory" 
                            class="form-input"
                            placeholder="Enter new category..."
                            maxlength="50"
                        >
                    </div>
                </div>

                <div class="form-group">
                    <label for="tags">Tags</label>
                    <input 
                        type="text" 
                        id="tags" 
                        name="tags" 
                        value="<%= note.tags.join(', ') %>"
                        class="form-input"
                        placeholder="Enter tags separated by commas (e.g., node, javascript, tutorial)"
                    >
                    <small class="form-hint">Separate multiple tags with commas</small>
                </div>

                <div class="form-group checkboxes">
                    <label class="checkbox-label">
                        <input type="checkbox" name="favorite" <%= note.favorite ? 'checked' : '' %>>
                        <span>⭐ Mark as Favorite</span>
                    </label>
                    
                    <label class="checkbox-label">
                        <input type="checkbox" name="pinned" <%= note.pinned ? 'checked' : '' %>>
                        <span>📌 Pin Note</span>
                    </label>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-primary btn-large">Update Note</button>
                    <a href="/notes/<%= note._id %>" class="btn-secondary btn-large">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
