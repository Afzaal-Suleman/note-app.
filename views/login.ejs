<%- include('partials/header') %>

<main class="main-content">
    <div class="container">
        <!-- Toast Message -->
        <% if (typeof message !== 'undefined' && message) { %>
            <div class="toast <%= messageType === 'success' ? 'toast-success' : 'toast-error' %>">
                <%= message %>
            </div>
        <% } %>

        <div class="login-container">
            <div class="login-card">
                <h1 class="login-title">Login</h1>
                <p class="login-subtitle">Enter password to access note management</p>
                
                <% if (error) { %>
                    <div class="error-message">
                        <%= error %>
                    </div>
                <% } %>
                
                <form action="/login" method="POST" class="login-form">
                    <div class="form-group">
                        <label for="password">Password</label>
                        <input 
                            type="password" 
                            id="password" 
                            name="password" 
                            class="form-control" 
                            placeholder="Enter password" 
                            required
                            autofocus
                        >
                    </div>
                    
                    <button type="submit" class="btn-primary btn-large btn-block">Login</button>
                </form>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
